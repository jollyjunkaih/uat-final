{
  "name": "uat-final",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "migrate": "node ace migration:run",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project inertia/tsconfig.json",
    "convert-gifs": "node ace convert:gifs",
    "docs:setup": "cd docs-site && npm install",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:deploy": "node scripts/build-docs.mjs --deploy",
    "docs:preview": "node scripts/build-docs.mjs --no-git && cd docs-site && npx astro preview"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#utils/*": "./app/utils/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.2",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.1.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.0",
    "@adonisjs/vite": "^5.1.0",
    "@inertiajs/react": "^2.3.17",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tuyau/core": "^1.0.0",
    "@vinejs/vine": "^4.3.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "docx": "^9.6.0",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "yaml": "^2.8.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
